# InferenceHub environment variables
# Copy this file to .env and fill in your values.
# The CLI auto-loads .env, .env.local, and ~/.inferencehub/.env

# ── Required ──────────────────────────────────────────────────────────────────
# LiteLLM gateway API key. Must start with "sk-".
# Used by OpenWebUI to call LiteLLM, and by external API consumers.
LITELLM_MASTER_KEY=sk-your-secret-key-here

# ── Observability (optional) ──────────────────────────────────────────────────
# Required only when observability.enabled: true in config.yaml
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── External datastores (optional) ───────────────────────────────────────────
# Required only when postgresql.url / redis.url is set in config.yaml
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# ── Model provider API keys (optional) ───────────────────────────────────────
# Required only when the corresponding provider is listed under models in config.yaml
# AWS Bedrock uses IRSA — no key needed here
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
